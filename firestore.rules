rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isValidNim(nim) {
      return nim is string && nim.size() >= 5 && nim.size() <= 20;
    }

    function hasCampusEmail() {
      return request.auth != null &&
        request.auth.token.email is string &&
        request.auth.token.email.matches('^[^@]+@([a-zA-Z0-9-]+\\.)*itb\\.ac\\.id$');
    }

    function isAdmin() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/admin_users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/admin_users/$(request.auth.uid)).data.active == true;
    }

    function isOwnerNim(nim) {
      return request.auth != null &&
        hasCampusEmail() &&
        request.auth.token.email.matches('^' + nim + '[^@]*@([a-zA-Z0-9-]+\\.)*itb\\.ac\\.id$');
    }

    function isValidVoteWeight(weight) {
      return weight in [1, 1.5, 2];
    }

    function isVotingOpen() {
      return !exists(/databases/$(database)/documents/site_settings/voting_gate) ||
        get(/databases/$(database)/documents/site_settings/voting_gate).data.isOpen == true;
    }

    function isValidHearingClassification(value) {
      return !(value is string) || value in ["", "awal_only", "akhir_only", "awal_akhir", "tidak_valid", "dari_users_doc"];
    }

    function isAllowedHearingSyncFields() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        "statusHearing",
        "status_hearing",
        "hearingClassification",
        "hearingUpdatedAt",
        "updatedAt",
        "presensiAwalAt",
        "presensiAkhirAt",
        "presensiAwalProofUrl",
        "presensiAkhirProofUrl",
        "checkInAt",
        "checkOutAt",
        "checkInProofUrl",
        "checkOutProofUrl"
      ]);
    }

    function isAllowedHearingCreateFields() {
      return request.resource.data.keys().hasOnly([
        "nim",
        "statusHearing",
        "status_hearing",
        "hearingClassification",
        "hearingUpdatedAt",
        "updatedAt",
        "presensiAwalAt",
        "presensiAkhirAt",
        "presensiAwalProofUrl",
        "presensiAkhirProofUrl",
        "checkInAt",
        "checkOutAt",
        "checkInProofUrl",
        "checkOutProofUrl"
      ]);
    }

    function isValidHearingSyncPayload(nim) {
      return request.resource.data.nim == nim &&
        request.resource.data.statusHearing is bool &&
        request.resource.data.status_hearing is bool &&
        (!("hearingClassification" in request.resource.data) || isValidHearingClassification(request.resource.data.hearingClassification)) &&
        (!("hearingUpdatedAt" in request.resource.data) || request.resource.data.hearingUpdatedAt is timestamp) &&
        (!("updatedAt" in request.resource.data) || request.resource.data.updatedAt is timestamp) &&
        (!("presensiAwalAt" in request.resource.data) || request.resource.data.presensiAwalAt is timestamp) &&
        (!("presensiAkhirAt" in request.resource.data) || request.resource.data.presensiAkhirAt is timestamp) &&
        (!("presensiAwalProofUrl" in request.resource.data) || request.resource.data.presensiAwalProofUrl is string) &&
        (!("presensiAkhirProofUrl" in request.resource.data) || request.resource.data.presensiAkhirProofUrl is string) &&
        (!("checkInAt" in request.resource.data) || request.resource.data.checkInAt is timestamp) &&
        (!("checkOutAt" in request.resource.data) || request.resource.data.checkOutAt is timestamp) &&
        (!("checkInProofUrl" in request.resource.data) || request.resource.data.checkInProofUrl is string) &&
        (!("checkOutProofUrl" in request.resource.data) || request.resource.data.checkOutProofUrl is string);
    }

    match /users/{nim} {
      allow read: if true;

      allow create, update: if
        (
          isOwnerNim(nim) &&
          isVotingOpen() &&
          isValidNim(nim) &&
          request.resource.data.nim == nim &&
          request.resource.data.sudahVote == true &&
          request.resource.data.statusHearing is bool &&
          request.resource.data.voterUid == request.auth.uid &&
          request.resource.data.voterEmail == request.auth.token.email &&
          (
            !("bobotSuara" in request.resource.data) ||
            isValidVoteWeight(request.resource.data.bobotSuara)
          )
        ) ||
        (
          isAdmin() &&
          isValidNim(nim) &&
          request.resource.data.nim == nim &&
          (
            !("bobotSuara" in request.resource.data) ||
            isValidVoteWeight(request.resource.data.bobotSuara)
          )
        ) ||
        (
          isOwnerNim(nim) &&
          isValidNim(nim) &&
          (
            (resource == null && isAllowedHearingCreateFields()) ||
            (resource != null && isAllowedHearingSyncFields())
          ) &&
          isValidHearingSyncPayload(nim)
        );

      allow delete: if false;
    }

    match /suara_masuk/{nim} {
      allow create: if
        isOwnerNim(nim) &&
        isVotingOpen() &&
        isValidNim(nim) &&
        !exists(/databases/$(database)/documents/suara_masuk/$(nim)) &&
        request.resource.data.nim == nim &&
        request.resource.data.voterUid == request.auth.uid &&
        request.resource.data.voterEmail == request.auth.token.email &&
        request.resource.data.candidateId is string &&
        request.resource.data.candidateId.size() > 0 &&
        request.resource.data.statusHearing is bool &&
        isValidVoteWeight(request.resource.data.bobotSuara);

      allow read: if true;
      allow update, delete: if false;
    }

    match /admin_users/{uid} {
      allow read: if
        request.auth != null &&
        (
          request.auth.uid == uid ||
          request.auth.token.email == uid ||
          request.auth.token.email.matches('^' + uid + '[^@]*@([a-zA-Z0-9-]+\\.)*itb\\.ac\\.id$')
        );
      allow write: if false;
    }

    match /developer_audit_logs/{logId} {
      allow create: if
        request.auth != null &&
        request.resource.data.actorUid == request.auth.uid &&
        request.resource.data.actorEmail == request.auth.token.email &&
        request.resource.data.eventType is string;

      allow read: if isAdmin();
      allow update, delete: if false;
    }

    match /hearing_settings/{settingId} {
      allow read: if request.auth != null;
      allow create, update, delete: if isAdmin();
    }

    match /hearing_sessions/{sessionId} {
      allow read: if request.auth != null;
      allow create, update, delete: if isAdmin();
    }

    match /hearing_attendance/{nim} {
      allow read: if isAdmin() || isOwnerNim(nim);

      allow create, update: if
        isOwnerNim(nim) &&
        request.resource.data.nim == nim &&
        request.resource.data.uid == request.auth.uid &&
        request.resource.data.email == request.auth.token.email &&
        request.resource.data.statusHearing is bool &&
        request.resource.data.status_hearing is bool;

      allow delete: if false;
    }

    match /site_announcements/{announcementId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /site_settings/{settingId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /support_threads/{threadId} {
      allow create: if
        request.auth != null &&
        request.resource.data.requesterUid == request.auth.uid &&
        request.resource.data.requesterEmail == request.auth.token.email &&
        request.resource.data.status == "open";

      allow read: if
        isAdmin() ||
        (request.auth != null && resource.data.requesterUid == request.auth.uid);

      allow update: if
        isAdmin() ||
        (request.auth != null && resource.data.requesterUid == request.auth.uid);

      allow delete: if false;

      match /messages/{messageId} {
        allow read: if
          isAdmin() ||
          (
            request.auth != null &&
            get(/databases/$(database)/documents/support_threads/$(threadId)).data.requesterUid == request.auth.uid
          );

        allow create: if
          (
            isAdmin() &&
            request.auth != null &&
            request.resource.data.senderRole == "admin" &&
            request.resource.data.senderEmail == request.auth.token.email
          ) ||
          (
            request.auth != null &&
            get(/databases/$(database)/documents/support_threads/$(threadId)).data.requesterUid == request.auth.uid &&
            request.resource.data.senderRole == "user" &&
            request.resource.data.senderUid == request.auth.uid &&
            request.resource.data.senderEmail == request.auth.token.email
          );

        allow update, delete: if false;
      }
    }

    match /password_reset_chats/{chatId} {
      allow create: if
        request.resource.data.requesterNim is string &&
        request.resource.data.requesterEmail is string &&
        request.resource.data.status in ["open", "in_review", "resolved"];

      allow get: if true;
      allow list: if isAdmin();

      allow update: if
        isAdmin() ||
        (
          request.resource.data.requesterNim == resource.data.requesterNim &&
          request.resource.data.requesterEmail == resource.data.requesterEmail &&
          request.resource.data.lastSenderRole == "user" &&
          request.resource.data.status in ["open", "in_review", "resolved"]
        );

      allow delete: if false;

      match /messages/{messageId} {
        allow get, list: if true;

        allow create: if
          (
            isAdmin() &&
            request.auth != null &&
            request.resource.data.senderRole == "admin" &&
            request.resource.data.senderEmail == request.auth.token.email
          ) ||
          (
            request.resource.data.senderRole == "user" &&
            request.resource.data.senderEmail is string
          );

        allow update, delete: if false;
      }
    }

    match /user_profiles/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;

      allow create, update: if
        request.auth != null &&
        request.auth.uid == uid &&
        (!("uid" in request.resource.data) || request.resource.data.uid == uid) &&
        (!("nim" in request.resource.data) || request.resource.data.nim is string || request.resource.data.nim == null) &&
        (!("fullName" in request.resource.data) || request.resource.data.fullName is string) &&
        (!("nickName" in request.resource.data) || request.resource.data.nickName is string) &&
        (!("bio" in request.resource.data) || request.resource.data.bio is string) &&
        (!("updatedAt" in request.resource.data) || request.resource.data.updatedAt is timestamp);

      allow delete: if false;
    }
  }
}