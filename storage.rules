rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function hasCampusEmail() {
      return request.auth != null &&
        request.auth.token.email is string &&
        request.auth.token.email.matches('^[^@]+@(student\\.itb\\.ac\\.id|mahasiswa\\.itb\\.ac\\.id|itb\\.ac\\.id)$');
    }

    match /verifikasi-selfie/{nim}/{fileName} {
      allow read: if true;
      allow write: if
        hasCampusEmail() &&
        nim is string &&
        nim.size() >= 5 && nim.size() <= 20 &&
        request.resource.size < 5 * 1024 * 1024 &&
        request.resource.contentType.matches('image/.*');
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}